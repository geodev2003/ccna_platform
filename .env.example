# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=ccna_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=ccna_platform

# ── JWT (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=REPLACE_64_CHAR_HEX_HERE
JWT_REFRESH_SECRET=REPLACE_ANOTHER_64_CHAR_HEX_HERE

# ── Claude API (lấy tại console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── URLs (thay your-domain.com bằng domain thật của bạn)
FRONTEND_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1

# ── App
NODE_ENV=production
PORT=3001
