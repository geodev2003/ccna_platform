generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          Role     @default(STUDENT)
  avatarUrl     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  enrollments   Enrollment[]
  progress      LessonProgress[]
  quizAttempts  QuizAttempt[]
  labAttempts   LabAttempt[]
  activityLogs  ActivityLog[]
  refreshTokens RefreshToken[]
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("refresh_tokens")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

model Module {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  phase       Int
  orderIndex  Int
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessons     Lesson[]
  enrollments Enrollment[]
  @@map("modules")
}

model Lesson {
  id          String     @id @default(cuid())
  moduleId    String
  title       String
  slug        String
  type        LessonType
  orderIndex  Int
  durationMin Int        @default(30)
  isPublished Boolean    @default(false)
  isFree      Boolean    @default(false)
  content     Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  module      Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quizzes     Quiz[]
  labs        Lab[]
  progress    LessonProgress[]
  tags        LessonTag[]
  @@unique([moduleId, slug])
  @@map("lessons")
}

enum LessonType {
  THEORY
  LAB
  QUIZ_ONLY
  MIXED
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  color   String      @default("#6366f1")
  lessons LessonTag[]
  @@map("tags")
}

model LessonTag {
  lessonId String
  tagId    String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([lessonId, tagId])
  @@map("lesson_tags")
}

model Quiz {
  id            String   @id @default(cuid())
  lessonId      String
  title         String
  passingScore  Int      @default(70)
  timeLimit     Int?
  isAiGenerated Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lesson        Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions     Question[]
  attempts      QuizAttempt[]
  @@map("quizzes")
}

model Question {
  id          String       @id @default(cuid())
  quizId      String
  text        String
  explanation String?
  type        QuestionType
  orderIndex  Int
  points      Int          @default(1)
  quiz        Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options     QuestionOption[]
  answers     AttemptAnswer[]
  @@map("questions")
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  orderIndex Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@map("question_options")
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  FILL_BLANK
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Int
  maxScore    Int
  passed      Boolean
  timeTaken   Int
  completedAt DateTime @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz        Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers     AttemptAnswer[]
  @@map("quiz_attempts")
}

model AttemptAnswer {
  id          String   @id @default(cuid())
  attemptId   String
  questionId  String
  selectedIds String[]
  isCorrect   Boolean
  attempt     QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@map("attempt_answers")
}

model Lab {
  id            String   @id @default(cuid())
  lessonId      String
  title         String
  description   String
  topology      Json?
  instructions  Json
  objectives    String[]
  toolRequired  String   @default("Packet Tracer")
  durationMin   Int      @default(60)
  isAiGenerated Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lesson        Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts      LabAttempt[]
  @@map("labs")
}

model LabAttempt {
  id          String    @id @default(cuid())
  userId      String
  labId       String
  status      LabStatus @default(IN_PROGRESS)
  notes       String?
  timeTaken   Int?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab         Lab  @relation(fields: [labId], references: [id], onDelete: Cascade)
  @@map("lab_attempts")
}

enum LabStatus {
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  moduleId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module      Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  @@unique([userId, moduleId])
  @@map("enrollments")
}

model LessonProgress {
  id           String         @id @default(cuid())
  userId       String
  lessonId     String
  status       ProgressStatus @default(NOT_STARTED)
  timeSpentSec Int            @default(0)
  completedAt  DateTime?
  lastAccessAt DateTime?
  updatedAt    DateTime       @updatedAt
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson       Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@map("activity_logs")
}
